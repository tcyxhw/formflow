{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/mimo-v2-pro-free",
  "instructions": [
    "standards/00_ai_digest.md",
    "standards/01_principles.md",
    "standards/02_decision_matrix.md"
  ],
  "provider": {
    "opencode": {
      "models": {
        "mimo-v2-pro-free": {
          "options": {
            "reasoningEffort": "high"
          }
        }
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/mimo-v2-pro-free",
      "reasoningEffort": "high"
    },
    "task-intake": {
      "description": "任务入口分析代理",
      "mode": "subagent",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "grep *": "allow",
          "wc *": "allow",
          "sed *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow"
        },
        "webfetch": "deny"
      }
    },
    "risk-classifier": {
      "description": "风险分类代理",
      "mode": "subagent",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "grep *": "allow",
          "wc *": "allow",
          "sed *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow"
        },
        "webfetch": "deny"
      }
    },
    "planner-lite": {
      "description": "Lite/Normal 轻计划代理",
      "mode": "subagent",
      "permission": {
        "edit": {
          "*": "deny"
