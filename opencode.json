          "git show*": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "wc *": "allow",
          "sed *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow",
          "python3 scripts/evidence_context.py*": "allow",
          "pytest*": "allow",
          "git status*": "allow",
