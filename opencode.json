          "sed *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow"
        },
        "webfetch": "deny"
      }
    },
    "planner-strict": {
      "description": "Strict 严格计划代理",
      "mode": "subagent",
      "permission": {
        "edit": {
          "*": "deny"
        },
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "grep *": "allow",
          "wc *": "allow",
          "sed *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow"
        },
        "webfetch": "deny"
      }
