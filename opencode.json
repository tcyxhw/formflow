    "implementer": {
      "description": "实施代理，按计划做最小代码改动",
      "mode": "subagent",
      "permission": {
        "edit": {
          "*": "allow"
        },
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git status*": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "wc *": "allow",
          "sed *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow",
          "pytest*": "allow",
          "ruff check*": "allow",
          "mypy*": "allow",
          "npm run lint*": "allow",
          "npm run type-check*": "allow",
          "npm run build*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git fetch*": "allow",
          "cd my-app && npm run lint*": "allow",
          "cd my-app && npm run type-check*": "allow",
          "cd my-app && npm run build*": "allow",
          "cd backend && pytest*": "allow",
          "cd backend && ruff check*": "allow",
          "cd backend && mypy*": "allow"
        },
        "webfetch": "deny"
      }
    },
    "review-orchestrator": {
      "description": "总控审查代理：触发分域 review、汇总结果、更新 structured evidence、重建 dashboard",
      "mode": "subagent",
      "permission": {
        "edit": {
          "*": "deny",
          "evidence/active/*.json": "allow",
          "evidence/archive/*.json": "allow"
        },
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git fetch*": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "wc *": "allow",
          "sed *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "ls *": "allow",
          "mv evidence/*": "allow",
          "cp evidence/*": "allow",
          "python3 scripts/render_review_evidence.py*": "allow",
          "python3 scripts/evidence_context.py*": "allow",
          "pytest*": "allow",
          "ruff check*": "allow",
          "mypy*": "allow",
          "npm run lint*": "allow",
          "npm run type-check*": "allow",
          "npm run build*": "allow",
          "python3 scripts/ops_report.py*": "allow",
          "python3 scripts/doc_integrity_check.py*": "allow",
          "python3 scripts/hot_path_audit.py*": "allow",
          "python3 scripts/context_surface_report.py*": "allow",
          "cd my-app && npm run lint*": "allow",
          "cd my-app && npm run type-check*": "allow",
          "cd my-app && npm run build*": "allow",
          "cd backend && pytest*": "allow",
          "cd backend && ruff check*": "allow",
          "cd backend && mypy*": "allow"
        },
        "webfetch": "deny"
      }
    },
