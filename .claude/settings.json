{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.claude/settings.local.json)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(./*.pem)",
      "Read(./*.key)",
      "Read(./build)",
      "Read(./dist/**)"
    ]
  },
  "defaultMode": "plan",
  "disableBypassPermissionsMode": "disable"
}